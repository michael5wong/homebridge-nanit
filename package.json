{
  "name": "homebridge-nanit",
  "displayName": "Homebridge Nanit",
  "version": "1.0.0",
  "description": "Homebridge plugin for Nanit baby monitors - exposes cameras and sensors to HomeKit",
  "main": "dist/index.js",
  "bin": {
    "nanit-auth": "dist/cli.js"
  },
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "nanit",
    "baby-monitor",
    "camera",
    "homekit",
    "streaming",
    "rtmp"
  ],
  "engines": {
    "node": "^18.17.0 || ^20.9.0 || ^22.0.0",
    "homebridge": "^1.6.0 || ^2.0.0"
  },
  "author": "Michael Wong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael5wong/homebridge-nanit.git"
  },
  "bugs": {
    "url": "https://github.com/michael5wong/homebridge-nanit/issues"
  },
  "homepage": "https://github.com/michael5wong/homebridge-nanit#readme",
  "dependencies": {
    "node-media-server": "^4.2.4",
    "protobufjs": "^7.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "homebridge": "^1.8.0",
    "protobufjs-cli": "^1.2.0",
    "typescript": "^5.3.0"
  }
}
